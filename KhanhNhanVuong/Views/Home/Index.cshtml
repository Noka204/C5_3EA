@{
    ViewData["Title"] = "Trang Chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="leftPan">
    <div id="welcome">
        <h2></h2>
        <img src="~/images/img_welcome.jpg" width="172" height="56" alt="Welcome" />
        <p class="headline">Chào mừng đến với Floral Shop - Nơi hoa tươi hội tụ.</p>
        <p>
            Chúng tôi cung cấp hoa tươi cao cấp, được tuyển chọn kỹ lưỡng
            từ các vườn hoa trong và ngoài nước. Với hơn 10 năm kinh nghiệm,
            chúng tôi tự hào mang đến những bó hoa đẹp nhất cho mọi dịp đặc biệt.
        </p>
    </div>
</div>

<div id="rightPan">
    <div id="featured">
        <h2></h2>
        <p class="headline">Sản phẩm nổi bật tuần này tại Floral Shop.</p>
        <div class="featItem" id="i01">
            <img src="~/images/img_prod.jpg" width="116" height="125" alt="Hoa Hồng" />
            <p>
                <span class="headline2">Hoa Hồng Đỏ</span><br />
                <a href="/Home/Products">Xem chi tiết</a><br />
                Giá: 150,000 VNĐ/bó
            </p>
        </div>
        <div class="featItem" id="i02">
            <img src="~/images/img_prod-13.jpg" width="116" height="125" alt="Hoa Cúc" />
            <p>
                <span class="headline2">Hoa Cúc Trắng</span><br />
                <a href="/Home/Products">Xem chi tiết</a><br />
                Giá: 80,000 VNĐ/bó
            </p>
        </div>
        <div class="featItem" id="i03">
            <img src="~/images/img_prod-14.jpg" width="116" height="125" alt="Hoa Ly" />
            <p>
                <span class="headline2">Hoa Ly Vàng</span><br />
                <a href="/Home/Products">Xem chi tiết</a><br />
                Giá: 200,000 VNĐ/bó
            </p>
        </div>
        <div class="clear"></div>
    </div>
</div>
<div class="clear" id="end"></div>
