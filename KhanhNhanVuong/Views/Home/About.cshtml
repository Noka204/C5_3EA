@{
    ViewData["Title"] = "Giới Thiệu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="leftPan">
    <div id="welcome">
        <h2></h2>
        <img src="~/images/img_welcome.jpg" width="172" height="56" alt="About" />
        <p class="headline">Câu chuyện về Floral Shop</p>
        <p>
            Floral Shop được thành lập năm 2010 với niềm đam mê
            mang vẻ đẹp của thiên nhiên đến cuộc sống hàng ngày.
        </p>
    </div>
</div>

<div id="rightPan">
    <div id="featured">
        <h2></h2>
        <p class="headline">Đội ngũ chuyên nghiệp của chúng tôi</p>
        <p style="margin-bottom:10px;">
            Với hơn 50 nhân viên lành nghề, phục vụ hàng
            nghìn khách hàng mỗi tháng. Mỗi bó hoa được làm thủ công tỉ mỉ.
        </p>
        <p class="headline">Tầm nhìn và sứ mệnh</p>
        <p>Trở thành chuỗi cửa hàng hoa tươi hàng đầu Việt Nam.</p>
        <p class="headline" style="margin-top:10px;">Thành tích nổi bật</p>
        <p>
            🏆 Top 10 cửa hàng hoa uy tín TP.HCM 2023<br />
            ✅ Chứng nhận ISO 9001:2015<br />
            💐 Hơn 10,000 khách hàng hài lòng
        </p>
        <div class="clear"></div>
    </div>
</div>
<div class="clear" id="end"></div>
