@{
    ViewData["Title"] = "Liên Hệ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="leftPan">
    <div id="welcome">
        <h2></h2>
        <p class="headline">Thông tin liên hệ</p>
        <p style="margin-top:8px;"><strong>Địa chỉ:</strong></p>
        <p>123 Đường Hoa Hồng, Quận 1, TP.HCM</p>
        <p style="margin-top:8px;"><strong>Điện thoại:</strong></p>
        <p>(028) 3456 7890</p>
        <p style="margin-top:8px;"><strong>Email:</strong></p>
        <p>info@floralshop.vn</p>
        <p style="margin-top:8px;"><strong>Giờ mở cửa:</strong></p>
        <p>7:00 - 21:00 mỗi ngày</p>
    </div>
</div>

<div id="rightPan">
    <div id="featured">
        <h2></h2>
        <p class="headline">Gửi tin nhắn cho chúng tôi</p>
        <form method="post" action="#" style="margin-top:10px;">
            <p style="margin-bottom:6px;">
                <label>Họ tên:</label><br />
                <input type="text" name="name" style="width:250px;border:1px solid #ccc;padding:3px;" />
            </p>
            <p style="margin-bottom:6px;">
                <label>Email:</label><br />
                <input type="email" name="email" style="width:250px;border:1px solid #ccc;padding:3px;" />
            </p>
            <p style="margin-bottom:6px;">
                <label>Nội dung:</label><br />
                <textarea name="message" rows="4" style="width:250px;border:1px solid #ccc;padding:3px;"></textarea>
            </p>
            <p>
                <input type="submit" value="Gửi tin nhắn"
                       style="background:#9d1263;color:#fff;border:none;padding:5px 15px;cursor:pointer;" />
            </p>
        </form>
        <div class="clear"></div>
    </div>
</div>
<div class="clear" id="end"></div>
